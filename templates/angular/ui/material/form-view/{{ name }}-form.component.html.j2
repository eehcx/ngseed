<form [formGroup]="form" (ngSubmit)="onSubmit()">
  {% for field in fields %}
  <mat-form-field appearance="outline">
    <mat-label>{{ field.name | capitalize }}</mat-label>
    <input
      matInput
      formControlName="{{ field.name }}"
      {% if field.type == 'number' %}type="number"{% else %}type="text"{% endif %}
    />
    @if (form.get('{{ field.name }}')?.hasError('required')) {
      <mat-error>{{ field.name | capitalize }} is required</mat-error>
    }
  </mat-form-field>
  {% endfor %}

  <div class="form-actions">
    <button mat-stroked-button type="button" (click)="onCancel()">Cancel</button>
    <button
      mat-flat-button
      color="primary"
      type="submit"
      [disabled]="form.invalid || loading()"
    >
      @if (loading()) {
        <mat-spinner diameter="20" />
      } @else {
        {% raw %}{{ id() ? 'Update' : 'Create' }}{% endraw %}
      }
    </button>
  </div>
