  selector: 'app-{{ name_kebab }}-list',
  standalone: true,
  imports: [
    MatTableModule,
    MatButtonModule,
    MatIconModule,
    MatProgressSpinnerModule,
    MatSnackBarModule,
    RouterModule,
  ],
  templateUrl: './{{ name_kebab }}-list.component.html',
})
export class {{ name }}ListComponent implements OnInit {
  readonly #facade = inject({{ name }}Facade);
