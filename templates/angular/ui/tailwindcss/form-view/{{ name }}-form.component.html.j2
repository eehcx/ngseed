<div class="max-w-lg mx-auto p-6 bg-white rounded-lg shadow">
  <form [formGroup]="form" (ngSubmit)="onSubmit()" class="space-y-4">
    {% for field in fields %}
    <div class="flex flex-col gap-1">
      <label class="text-sm font-medium text-gray-700">
        {{ field.name | capitalize }}
        {% if field.required %}<span class="text-red-500">*</span>{% endif %}
      </label>
      <input
        formControlName="{{ field.name }}"
        {% if field.type == 'number' %}type="number"{% else %}type="text"{% endif %}
        class="border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
        [class.border-red-500]="form.get('{{ field.name }}')?.invalid && form.get('{{ field.name }}')?.touched"
      />
      @if (form.get('{{ field.name }}')?.hasError('required') && form.get('{{ field.name }}')?.touched) {
        <span class="text-xs text-red-500">{{ field.name | capitalize }} is required</span>
      }
    </div>
    {% endfor %}

    <div class="flex justify-end gap-3 pt-4">
      <button
        type="button"
        (click)="onCancel()"
        class="px-4 py-2 text-sm rounded-md border border-gray-300 hover:bg-gray-50"
      >
        Cancel
      </button>
      <button
        type="submit"
        [disabled]="form.invalid || loading()"
        class="px-4 py-2 text-sm rounded-md bg-blue-600 text-white hover:bg-blue-700 disabled:opacity-50"
      >
        @if (loading()) {
          <span class="animate-pulse">Saving...</span>
        } @else {
          {% raw %}{{ id() ? 'Update' : 'Create' }}{% endraw %}
        }
      </button>
    </div>
  </form>
</div>