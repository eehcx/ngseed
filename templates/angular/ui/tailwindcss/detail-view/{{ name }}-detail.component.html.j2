<div class="max-w-lg mx-auto p-6 bg-white rounded-lg shadow">
  @if (loading()) {
    <div class="flex justify-center items-center h-40">
      <div class="animate-spin rounded-full h-12 w-12 border-t-2 border-b-2 border-blue-500"></div>
    </div>
  }

  @if (error()) {
    <p class="text-red-500 text-sm">{% raw %}{{ error() }}{% endraw %}</p>
  }

  @if (!loading() && item()) {
    <div class="space-y-4">
      <h2 class="text-xl font-semibold text-gray-800">{{ name }} Detail</h2>

      <dl class="divide-y divide-gray-200">
        {% for field in fields %}
        <div class="py-3 flex justify-between text-sm">
          <dt class="font-medium text-gray-500">{{ field.name | capitalize }}</dt>
          <dd class="text-gray-800">{% raw %}{{ item()?.{% endraw %}{{ field.name }}{% raw %} }}{% endraw %}</dd>
        </div>
        {% endfor %}
      </dl>

      <div class="flex justify-end gap-3 pt-4">
        <a routerLink="../" class="px-4 py-2 text-sm rounded-md border border-gray-300 hover:bg-gray-50">
          Back
        </a>
        
          [routerLink]="['../', id(), 'edit']"
          class="px-4 py-2 text-sm rounded-md bg-blue-600 text-white hover:bg-blue-700"
        >
          Edit
        </a>
      </div>
    </div>
  }
</div>