import { inject, Injectable } from '@angular/core';
import { {{ name }}Store } from '../../../state/{{ name_kebab }}.store';
import { {{ name }}RemoteDatasource } from '../../../data/datasource/remote/{{ name_kebab }}.remote-datasource';
import { {{ name }}Model } from '../../../core/models/{{ name_kebab }}.model';

@Injectable({ providedIn: 'root' })
export class {{ name }}Facade {
  readonly #store = inject({{ name }}Store);
  readonly #remote = inject({{ name }}RemoteDatasource);

  readonly items = this.#store.items;
  readonly selected = this.#store.selected;
  readonly loading = this.#store.loading;
  readonly error = this.#store.error;
  readonly total = this.#store.total;

  loadAll(): void {
    this.#store.setLoading(true);
    this.#remote.getAll().subscribe({
      next: (res) => {
        this.#store.setItems(res.data);
        this.#store.setLoading(false);
      },
      error: (err) => {
        this.#store.setError(err.message);
        this.#store.setLoading(false);
      },
    });
  }

  loadById(id: string): void {
    this.#store.setLoading(true);
    this.#remote.getById(id).subscribe({
      next: (item) => {
        this.#store.setSelected(item);
        this.#store.setLoading(false);
      },
      error: (err) => {
        this.#store.setError(err.message);
        this.#store.setLoading(false);
      },
    });
  }

  create(payload: Partial<{{ name }}Model>): void {
    this.#remote.create(payload as {{ name }}Model).subscribe({
      next: (item) => this.#store.addItem(item),
      error: (err) => this.#store.setError(err.message),
    });
  }

  update(id: string, payload: Partial<{{ name }}Model>): void {
    this.#remote.update(id, payload).subscribe({
      next: (item) => this.#store.updateItem(id, item),
      error: (err) => this.#store.setError(err.message),
    });
  }

  delete(id: string): void {
    this.#remote.delete(id).subscribe({
      next: () => this.#store.removeItem(id),
      error: (err) => this.#store.setError(err.message),
    });
  }
}