import { Component, inject, OnInit, input } from '@angular/core';
import { ReactiveFormsModule, FormBuilder, Validators } from '@angular/forms';
import { InputTextModule } from 'primeng/inputtext';
import { ButtonModule } from 'primeng/button';
import { ProgressSpinnerModule } from 'primeng/progressspinner';
import { Router } from '@angular/router';
import { {{ name }}Facade } from '../../_shared/facade/{{ name_kebab }}.facade';

@Component({
  selector: 'app-{{ name_kebab }}-form',
  standalone: true,
  imports: [ReactiveFormsModule, InputTextModule, ButtonModule, ProgressSpinnerModule],
  templateUrl: './{{ name_kebab }}-form.component.html',
})
export class {{ name }}FormComponent implements OnInit {
  readonly id = input<string | null>(null);

  readonly #facade = inject({{ name }}Facade);
  readonly #fb = inject(FormBuilder);
  readonly #router = inject(Router);

  readonly loading = this.#facade.loading;
  readonly selected = this.#facade.selected;

  readonly form = this.#fb.group({
    {% for field in fields %}
    {{ field.name }}: [
      null as {{ field.type }} | null,
      {% if field.required %}[Validators.required]{% else %}[]{% endif %},
    ],
    {% endfor %}
  });

  ngOnInit(): void {
    if (this.id()) {
      this.#facade.loadById(this.id()!);
    }
  }

  ngOnChanges(): void {
    const item = this.selected();
    if (item) this.form.patchValue(item);
  }

  onSubmit(): void {
    if (this.form.invalid) return;
    const value = this.form.getRawValue();
    if (this.id()) {
      this.#facade.update(this.id()!, value);
    } else {
      this.#facade.create(value);
    }
    this.#router.navigate(['{{ prefix }}']);
  }

  onCancel(): void {
    this.#router.navigate(['{{ prefix }}']);
  }
}