import { Component, inject, OnInit } from '@angular/core';
import { TableModule } from 'primeng/table';
import { ButtonModule } from 'primeng/button';
import { ProgressSpinnerModule } from 'primeng/progressspinner';
import { ToastModule } from 'primeng/toast';
import { MessageService } from 'primeng/api';
import { RouterModule } from '@angular/router';
import { {{ name }}Facade } from '../../_shared/facade/{{ name_kebab }}.facade';

@Component({
  selector: 'app-{{ name_kebab }}-list',
  standalone: true,
  imports: [TableModule, ButtonModule, ProgressSpinnerModule, ToastModule, RouterModule],
  providers: [MessageService],
  templateUrl: './{{ name_kebab }}-list.component.html',
})
export class {{ name }}ListComponent implements OnInit {
  readonly #facade = inject({{ name }}Facade);
  readonly #toast = inject(MessageService);

  readonly items = this.#facade.items;
  readonly loading = this.#facade.loading;
  readonly error = this.#facade.error;

  readonly columns = [
    {% for field in fields %}
    { field: '{{ field.name }}', header: '{{ field.name | capitalize }}' },
    {% endfor %}
  ];

  ngOnInit(): void {
    this.#facade.loadAll();
  }

  onDelete(id: string): void {
    this.#facade.delete(id);
    this.#toast.add({ severity: 'success', summary: 'Deleted', detail: 'Record removed' });
  }
}