<section>
  @if (loading()) {
    <p>Loading...</p>
  }

  @if (error()) {
    <p class="error">{{ "{{ error() }}" }}</p>
  }

  @if (!loading() && !error()) {
    <ul>
      @for (item of items(); track item.id) {
        <li>
          {% for field in fields %}
          <span>{{ "{{ item." }}{{ field.name }}{{ " }}" }}</span>
          {% endfor %}
          <button (click)="selectItem(item)">Edit</button>
          <button (click)="deleteItem(item.id)">Delete</button>
        </li>
      }
    </ul>
  }
</section>